*.vcf

# SLURM logs (keep folder, ignore log files)
logs/*.out
logs/*.err
*.out
*.err
slurm-*.out

# R session files
.Rhistory
.RData
.Rproj.user/
*.Rproj

# Figures (optional - remove these lines if you want figures on GitHub)
# figures/

# System files
.DS_Store
__pycache__/
*.pyc
