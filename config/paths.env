# sc-eQTL pipeline — path configuration
# Edit these paths to match your system before running any scripts.

# --- Input data ---
EXPR_INPUT="/path/to/gene_expression/onek1k.seurat.rds"   # pre-QC Seurat object
GENO_DIR="/path/to/plink_files"                            # directory with chr_*.bed/bim/fam

# --- Pipeline outputs (one directory per step) ---
QC_DIR="/path/to/sc-eqtl/01_scrna_quality_control"
NORM_DIR="/path/to/sc-eqtl/02_expression_normalization"
CLUST_DIR="/path/to/sc-eqtl/03_cell_type_clustering"
PSEUDO_DIR="/path/to/sc-eqtl/04_pseudobulk_aggregation"
COV_DIR="/path/to/sc-eqtl/05_covariates_for_mapping"
RESID_DIR="/path/to/sc-eqtl/06_expression_residualization"
EQTL_DIR="/path/to/sc-eqtl/07_cis_eqtl_mapping"
FM_DIR="/path/to/sc-eqtl/08_fine_mapping"
